# zcc-bidding-system production environment template.
# Copy this file to .env on the production server and replace every CHANGE_ME value.

APP_NAME=bidding-system
DEPLOY_DIR=/opt/bidding-system
COMPOSE_PROJECT_NAME=bidding-system

TZ=Asia/Shanghai
NGINX_HTTP_PORT=80

MYSQL_DB=bia
MYSQL_USER=bia
MYSQL_PASSWORD=CHANGE_ME_MYSQL_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_MYSQL_ROOT_PASSWORD

REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

BIA_API_PORT=8889
BIA_DB_USERNAME=bia
BIA_DB_PASSWORD=CHANGE_ME_MYSQL_PASSWORD
BIA_REDIS_DATABASE=1
BIA_REDIS_TIMEOUT=3000ms
BIA_UPLOAD_ROOT=/app/files
BIA_JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
BIA_MAIL_CONFIG_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
BIA_JWT_EXPIRE_SECONDS=86400
BIA_ADMIN_LOGIN_URL=/#/login
BIA_AUTH_SMS_TEST_BYPASS_ENABLED=false
BIA_AUTH_SMS_TEST_BYPASS_CODE=disabled

JAVA_OPTS=-Xms256m -Xmx512m -Djava.security.egd=file:/dev/./urandom
