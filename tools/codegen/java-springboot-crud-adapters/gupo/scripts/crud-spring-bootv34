     */
    @Operation(summary = "更新")
    @PostMapping("/update")
//    @RequireIdentity({RealCurrentIdentEnum.PLAT_ADMIN})
    public ResultWrapper<${ENTITY_NAME}ShowVO> update(@Valid @RequestBody ${ENTITY_NAME}UpdateReq request) {
        return ResultWrapper.success(${entity_var}Service.update(request));
    }

    /**
     * [CRUD-CODEGEN] 本方法由 CRUD-CODEGEN 脚手架生成，请结合实际业务调整。
     *
     * 批量创建${DISPLAY_NAME}
     *
     * @param request 批量创建请求
     * @return 执行结果
     */
    @Operation(summary = "批量创建")
    @PostMapping("/batch-create")
//    @RequireIdentity({RealCurrentIdentEnum.PLAT_ADMIN})
    public ResultWrapper<Boolean> batchCreate(@RequestBody List<@Valid ${ENTITY_NAME}CreateReq> request) {
        return ResultWrapper.success(${entity_var}Service.batchCreate(request));
    }

    /**
     * [CRUD-CODEGEN] 本方法由 CRUD-CODEGEN 脚手架生成，请结合实际业务调整。
     *
     * 批量更新${DISPLAY_NAME}
     *
     * @param request 批量更新请求
     * @return 执行结果
     */
    @Operation(summary = "批量更新")
    @PostMapping("/batch-update")
//    @RequireIdentity({RealCurrentIdentEnum.PLAT_ADMIN})
    public ResultWrapper<Boolean> batchUpdate(@RequestBody List<@Valid ${ENTITY_NAME}UpdateReq> request) {
        return ResultWrapper.success(${entity_var}Service.batchUpdate(request));
    }

    /**
     * [CRUD-CODEGEN] 本方法由 CRUD-CODEGEN 脚手架生成，请结合实际业务调整。
     *
     * 批量删除${DISPLAY_NAME}
     *
     * @param request 批量删除请求
     * @return 执行结果
     */
    @Operation(summary = "批量删除")
    @PostMapping("/batch-delete")
//    @RequireIdentity({RealCurrentIdentEnum.PLAT_ADMIN})
    public ResultWrapper<Boolean> batchDelete(@Valid @RequestBody ${ENTITY_NAME}BatchDeleteReq request) {
        return ResultWrapper.success(${entity_var}Service.batchDelete(request.getPkIdList()));
    }

    /**
     * [CRUD-CODEGEN] 本方法由 CRUD-CODEGEN 脚手架生成，请结合实际业务调整。
     *
     * 查询${DISPLAY_NAME}详情
     *
     * @param pkId 主键ID
     * @return 详情结果
     */
    @Operation(summary = "详情")
    @GetMapping("/show")
    public ResultWrapper<${ENTITY_NAME}ShowVO> show(
            @Parameter(description = "${escaped_pk_comment}", required = true, example = "1")
            @NotNull(message = "${escaped_pk_comment}不能为空")
            @RequestParam("pk_id") Long pkId
    ) {
        return ResultWrapper.success(${entity_var}Service.show(pkId));
    }

    /**
     * [CRUD-CODEGEN] 本方法由 CRUD-CODEGEN 脚手架生成，请结合实际业务调整。
     *
     * 删除${DISPLAY_NAME}
     *
     * @param pkId 主键ID
     * @return 删除结果
     */
    @Operation(summary = "删除")
    @PostMapping("/delete")
//    @RequireIdentity({RealCurrentIdentEnum.PLAT_ADMIN})
    public ResultWrapper<Boolean> delete(
            @Parameter(description = "${escaped_pk_comment}", required = true, example = "1")
            @NotNull(message = "${escaped_pk_comment}不能为空")
            @RequestParam("pk_id") Long pkId
    ) {
        return ResultWrapper.success(${entity_var}Service.delete(pkId));
    }
${enable_controller_block}
${batch_status_controller_block}

    /**
     * [CRUD-CODEGEN] 本方法由 CRUD-CODEGEN 脚手架生成，请结合实际业务调整。
     *
     * 分页查询${DISPLAY_NAME}
     *
     * @param request 分页请求
     * @return 分页结果
     */
    @Operation(summary = "分页列表")
    @PostMapping("/page-all")
    public ResultWrapper<PageInfo<${ENTITY_NAME}VO>> pageAll(@RequestBody(required = false) ${ENTITY_NAME}PageReq request) {
        return ResultWrapper.success(${entity_var}Service.pageAll(request));
    }

    /**
     * [CRUD-CODEGEN] 本方法由 CRUD-CODEGEN 脚手架生成，请结合实际业务调整。
     *
     * 查询全部${DISPLAY_NAME}
     *
     * @param request 查询参数
     * @return 列表结果
     */
    @Operation(summary = "全部")
    @PostMapping("/all")
    public ResultWrapper<List<${ENTITY_NAME}VO>> all(@RequestBody(required = false) ${ENTITY_NAME}PageReq request) {
        return ResultWrapper.success(${entity_var}Service.all(request));
    }
}
EOF
}

write_file() {
  local file_path="$1"
  local content="$2"
  local dir_path shown_path
  dir_path="$(dirname "$file_path")"
  shown_path="$(display_path "$file_path")"

  if [ "$PREVIEW" = "true" ]; then
    if [ -f "$file_path" ]; then
      if [ "$FORCE" = "true" ]; then
        printf '%b  [覆盖] %s%b\n' "${COLOR_YELLOW}" "$shown_path" "${COLOR_RESET}"
        print_change_preview "$file_path" "$content" "覆盖预览"
      else
        printf '%b%b  [追加] %s%b\n' "${COLOR_BOLD}" "${COLOR_RED}" "$shown_path" "${COLOR_RESET}"
        if is_model_file_path "$file_path"; then
          printf '%b%b    Model 已存在，建议优先人工核对字段差异再合并。%b\n' "${COLOR_BOLD}" "${COLOR_RED}" "${COLOR_RESET}"
        fi
        print_change_preview "$file_path" "$content" "追加预览"
      fi
    else
      printf '%b  [新增] %s%b\n' "${COLOR_GREEN}" "$shown_path" "${COLOR_RESET}"
    fi
    return
  fi

  mkdir -p "$dir_path"

  if [ -f "$file_path" ] && [ "$FORCE" != "true" ]; then
    append_to_existing_file "$file_path" "$content"
    return
  fi

  printf '%s' "$content" > "$file_path"
  printf '%b  [完成] %s%b\n' "${COLOR_GREEN}" "$shown_path" "${COLOR_RESET}"
}

append_to_existing_file() {
  local file_path="$1"
  local content="$2"

  case "$file_path" in
    *.java)
      append_java_template "$file_path" "$content"
      ;;
    *.xml)
      append_xml_template "$file_path" "$content"
      ;;
    *)
      printf '\n%s\n%s\n' "$(append_marker)" "$content" >> "$file_path"
      ;;
  esac

  APPENDED_FILES+=("$file_path")
  printf '%b%b  [追加完成] %s%b\n' "${COLOR_BOLD}" "${COLOR_RED}" "$(display_path "$file_path")" "${COLOR_RESET}"
  if is_model_file_path "$file_path"; then
    printf '%b%b    Model 已存在，建议优先人工核对字段差异再合并。%b\n' "${COLOR_BOLD}" "${COLOR_RED}" "${COLOR_RESET}"
  fi
  print_change_preview "$file_path" "$content" "已追加模板"
}

append_java_template() {
  local file_path="$1"
  local content="$2"
  local safe_content
  safe_content="${content//\*\//\* /}"

  {
    printf '\n/*\n'
    printf '%s\n' "$(append_marker)"
    printf '%s\n' "$safe_content"
    printf '*/\n'
  } >> "$file_path"
}

append_xml_template() {
  local file_path="$1"
  local content="$2"
  local tmp_file block_file inserted line block_id
  tmp_file="$(mktemp)"
  block_file="$(mktemp)"
  block_id="sh_append_$(date '+%Y%m%d%H%M%S')"

  {
    printf '    <sql id="%s">\n' "$block_id"
    printf '        &lt;!--%s--&gt;\n' "$(append_marker)"
    printf '%s' "$content" \
      | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g' \
      | sed 's/^/        /'
    printf '\n'
    printf '    </sql>\n'
  } > "$block_file"

  inserted="false"
  while IFS= read -r line || [ -n "$line" ]; do
    if [ "$line" = "</mapper>" ]; then
      cat "$block_file" >> "$tmp_file"
      inserted="true"
    fi
    printf '%s\n' "$line" >> "$tmp_file"
  done < "$file_path"

  if [ "$inserted" != "true" ]; then
    cat "$block_file" >> "$tmp_file"
  fi

  mv "$tmp_file" "$file_path"
  rm -f "$block_file"
}

summarize_content() {
  local content="$1"
  local summary
  summary="$(printf '%s\n' "$content" | awk '
    /^[[:space:]]*$/ { next }
    /^[[:space:]]*package / { next }
    /^[[:space:]]*import / { next }
    /^[[:space:]]*\/\// { next }
    /^[[:space:]]*\*/ { next }
    /^[[:space:]]*@/ {
      if ($0 ~ /@(Operation|PostMapping|GetMapping|RequestMapping|Transactional|Slf4j|RestController|Service|Schema|Tag)/) {
        print;
        count++;
      }
      if (count >= 6) exit;
      next;
    }
    /^[[:space:]]*public class / || /^[[:space:]]*public interface / {
      print;
      count++;
      if (count >= 6) exit;
      next;
    }
    /^[[:space:]]*public / || /^[[:space:]]*boolean / || /^[[:space:]]*List</ || /^[[:space:]]*PageInfo</ {
      print;
      count++;
      if (count >= 6) exit;
      next;
    }
    /<select id=/ || /<sql id=/ || /<mapper namespace=/ {
      print;
      count++;
      if (count >= 6) exit;
      next;
    }
  ')"
  if [ -z "$summary" ]; then
    summary="$(printf '%s\n' "$content" | sed '/^[[:space:]]*$/d' | head -n 6)"
  fi
  printf '%s' "$summary"
}

print_change_preview() {
  local file_path="$1"
  local content="$2"
  local mode="$3"
  local shown_path summary
  shown_path="$(display_path "$file_path")"
  summary="$(summarize_content "$content")"
  [ -z "$summary" ] && return
  printf '%b%b    关键片段摘要（%s）: %s%b\n' "${COLOR_BOLD}" "${COLOR_CYAN}" "$mode" "$shown_path" "${COLOR_RESET}"
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    printf '      %s\n' "$line"
  done <<< "$summary"
}

print_rule_summary() {
  local status_mode delete_mode status_feature delete_tip existence_tip
  delete_mode="$(resolve_delete_mode)"
  if column_exists "status"; then
    status_mode="已启用（DDL 中检测到 status 字段）"
    status_feature="将生成 enable + batchStatus"
  else
    status_mode="未启用（DDL 中未检测到 status 字段）"
    status_feature="enable / batchStatus 仅保留注释模板"
  fi
  if column_exists "is_deleted"; then
    delete_tip="DDL 中检测到 is_deleted 字段，删除与批量删除默认按软删除生成。"
    existence_tip="存在性校验默认附带 is_deleted = 0"
  else
    delete_tip="DDL 中未检测到 is_deleted 字段，删除与批量删除默认按硬删除生成。"
    existence_tip="存在性校验按物理数据存在判断，不附加 is_deleted 条件"
  fi

  printf '%b生成规则摘要%b\n' "${COLOR_BOLD}" "${COLOR_RESET}"
  echo "  - 删除模式: ${delete_mode}"
  printf '%b%b  - 删除提示: %s%b\n' "${COLOR_BOLD}" "${COLOR_RED}" "${delete_tip}" "${COLOR_RESET}"
  echo "  - 状态能力: ${status_mode}"
  echo "    生成项: ${status_feature}"
  echo "  - 存在性校验: ${existence_tip}"
  printf '%b%b  - 分页基类提示: 当前模板默认继承 PageDomain，如目标项目规范要求 BaseParam，请生成后按需调整 PageReq%b\n' "${COLOR_BOLD}" "${COLOR_RED}" "${COLOR_RESET}"
  echo "  - 字符串查询: code 精确匹配，name/title 模糊匹配，其他字符串默认精确匹配"
  echo "  - 批量限制: 最大 ${MAX_BATCH_SIZE} 条，自动判空、去重，并生成日志、try catch、事务模板"
}

print_route_summary() {
  echo "${COLOR_BOLD}接口路由摘要${COLOR_RESET}"
  echo "  - POST ${ROUTE_PATH}/create"
  echo "  - POST ${ROUTE_PATH}/update"
  echo "  - POST ${ROUTE_PATH}/batch-create"
  echo "  - POST ${ROUTE_PATH}/batch-update"
  echo "  - POST ${ROUTE_PATH}/batch-delete"
  echo "  - GET  ${ROUTE_PATH}/show"
  echo "  - POST ${ROUTE_PATH}/delete"
  if column_exists "status"; then
    echo "  - POST ${ROUTE_PATH}/enable"
    echo "  - POST ${ROUTE_PATH}/batch-status"
  else
    printf '%b%b  - 状态接口提示: 当前 DDL 未包含 status 字段，enable / batch-status 仅保留注释模板%b\n' "${COLOR_BOLD}" "${COLOR_RED}" "${COLOR_RESET}"
  fi
  echo "  - POST ${ROUTE_PATH}/page-all"
  echo "  - POST ${ROUTE_PATH}/all"
}

print_suggestions() {
  printf '%b建议检查项%b\n' "${COLOR_BOLD}" "${COLOR_RESET}"
  printf '%b%b  - 优先检查 PageReq 的继承关系，确认是否继续使用 PageDomain，或改为目标项目中的 BaseParam。%b\n' "${COLOR_BOLD}" "${COLOR_RED}" "${COLOR_RESET}"
  if column_exists "is_deleted"; then
    echo "  - 当前删除模式为软删除，建议确认 delete / batchDelete 与实际业务约定一致。"
  else
    printf '%b%b  - 当前删除模式为硬删除，建议重点确认 delete / batchDelete 是否允许物理删除。%b\n' "${COLOR_BOLD}" "${COLOR_RED}" "${COLOR_RESET}"
  fi
  if column_exists "status"; then
    echo "  - 当前已生成 enable / batchStatus，建议确认状态值 0/1/9 是否符合项目枚举定义。"
  else
    echo "  - 当前未生成真实状态接口，如后续表结构补充 status 字段，可重新生成模板。"
  fi
  echo "  - 建议检查 Mapper.xml 的筛选条件、字符串匹配策略与排序规则是否符合实际查询场景。"
  echo "  - 如果存在红色高亮的追加文件，请优先逐个复核后再手动合并。"
}

generate_all() {
  local java_base xml_base
  java_base="$(java_base_path)"
  xml_base="$(xml_base_path)"

  cyan_bold_line "==================== CRUD Codegen ===================="
  printf '%b执行信息%b\n' "${COLOR_BOLD}" "${COLOR_RESET}"
  echo "  - 项目根目录: ."
  echo "  - 模板版本: Spring Boot 3/4（Jakarta + OpenAPI 3）"
  echo "  - 基础包名: ${BASE_PACKAGE}"
  echo "  - 基础包名来源: ${BASE_PACKAGE_SOURCE}"
  echo "  - Java 输出目录: ${JAVA_BASE_DIR}"
  echo "  - XML 输出目录: ${RESOURCES_BASE_DIR}"
  echo "  - 实体名称: ${ENTITY_NAME}"
  echo "  - 模块路径: ${MODULE_PATH}"
  echo "  - 数据表名: ${TABLE_NAME}"
  echo "  - 路由前缀: ${ROUTE_PATH}"
  if [ -n "$DDL" ]; then
    echo "  - DDL: 已启用"
  fi
  if [ "$PREVIEW" = "true" ]; then
    echo "  - 模式: 预览"
  else
    echo "  - 模式: 正式生成"
  fi
  if [ "$FORCE" = "true" ]; then
    if [ "$FORCE_TOKEN_VERIFIED" = "true" ]; then
      echo "  - 覆盖确认: 已通过一次性安全码校验"
    else
      echo "  - 覆盖确认: 未触发安全码校验"
    fi
  fi
  echo
  print_rule_summary
  echo
  print_route_summary
  echo
  printf '%b文件处理结果%b\n' "${COLOR_BOLD}" "${COLOR_RESET}"

  write_file "$java_base/${MODEL_PATH}/${ENTITY_NAME}.java" "$(render_model)"
  write_file "$java_base/${REQ_PATH}/${ENTITY_NAME}CreateReq.java" "$(render_create_req)"
  write_file "$java_base/${REQ_PATH}/${ENTITY_NAME}UpdateReq.java" "$(render_update_req)"
  write_file "$java_base/${REQ_PATH}/${ENTITY_NAME}BatchDeleteReq.java" "$(render_batch_delete_req)"
  if column_exists "status"; then
    write_file "$java_base/${REQ_PATH}/${ENTITY_NAME}BatchStatusReq.java" "$(render_batch_status_req)"
  fi
  write_file "$java_base/${REQ_PATH}/${ENTITY_NAME}PageReq.java" "$(render_page_req)"
  write_file "$java_base/${VO_PATH}/${ENTITY_NAME}VO.java" "$(render_vo)"
  write_file "$java_base/${VO_PATH}/${ENTITY_NAME}ShowVO.java" "$(render_show_vo)"
  write_file "$java_base/${MAPPER_PATH}/${ENTITY_NAME}Mapper.java" "$(render_mapper)"
  if [ -n "$XML_PATH" ] && [ "$XML_PATH" != "." ]; then
    write_file "$xml_base/${XML_PATH}/${ENTITY_NAME}Mapper.xml" "$(render_mapper_xml)"
  else
    write_file "$xml_base/${ENTITY_NAME}Mapper.xml" "$(render_mapper_xml)"
  fi
  write_file "$java_base/${SERVICE_PATH}/${ENTITY_NAME}Service.java" "$(render_service)"
  write_file "$java_base/${SERVICE_IMPL_PATH}/${ENTITY_NAME}ServiceImpl.java" "$(render_service_impl)"
  write_file "$java_base/${CONTROLLER_PATH}/${ENTITY_NAME}Controller.java" "$(render_controller)"

  if [ "$PREVIEW" != "true" ] && [ "${#APPENDED_FILES[@]}" -gt 0 ]; then
    echo
    red_bold_line "人工复核提示"
    echo "  当前未使用 --force，且目标文件已存在。"
    echo "  以下文件本次采用“追加模板片段”方式写入，建议逐个检查后再手动合并："
    for file_path in "${APPENDED_FILES[@]}"; do
      printf '%b%b  - %s%b\n' "${COLOR_BOLD}" "${COLOR_RED}" "$(display_path "$file_path")" "${COLOR_RESET}"
    done
    if printf '%s\n' "${APPENDED_FILES[@]}" | grep -Fxq "$(model_target_file)"; then
      printf '%b%b  - Model 已存在，建议优先人工核对字段差异再合并。%b\n' "${COLOR_BOLD}" "${COLOR_RED}" "${COLOR_RESET}"
    fi
  fi

  echo
  if [ "$PREVIEW" = "true" ]; then
    printf '%b预览完成%b\n' "${COLOR_BOLD}" "${COLOR_RESET}"
    echo "  本次未写入任何文件，可根据上面的规则摘要和文件列表决定是否正式生成。"
  else
    green_line "${COLOR_BOLD}生成完成${COLOR_RESET}"
    echo "  脚手架文件已写入当前项目，请优先检查 Req、ServiceImpl、Mapper.xml 与删除/状态逻辑是否符合实际业务。"
    echo
    print_suggestions
  fi
  cyan_bold_line "======================================================"
}

parse_args "$@"
normalize_project_root
apply_default_base_dirs
require_non_empty "--entity-name" "$ENTITY_NAME"
require_non_empty "--module-path" "$MODULE_PATH"
require_non_empty "--route-path" "$ROUTE_PATH"
require_non_empty "--display-name" "$DISPLAY_NAME"
resolve_base_package
validate_base_package
validate_entity_name
validate_project_root
validate_path_value "--module-path" "$MODULE_PATH"
validate_route_path
resolve_layer_paths
validate_path_value "--model-path" "$MODEL_PATH"
validate_path_value "--req-path" "$REQ_PATH"
validate_path_value "--vo-path" "$VO_PATH"
validate_path_value "--controller-path" "$CONTROLLER_PATH"
validate_path_value "--service-path" "$SERVICE_PATH"
validate_path_value "--service-impl-path" "$SERVICE_IMPL_PATH"
validate_path_value "--mapper-path" "$MAPPER_PATH"
if [ -n "$XML_PATH" ] && [ "$XML_PATH" != "." ]; then
  validate_path_value "--xml-path" "$XML_PATH"
fi
prepare_fields
require_non_empty "--table-name 或 --ddl 中的表名" "$TABLE_NAME"
enforce_force_token_if_needed
generate_all
if [ "$FORCE_TOKEN_VERIFIED" = "true" ]; then
  invalidate_force_token
fi
