render_service_impl() {
  local entity_var model_package req_package vo_package mapper_package service_package service_impl_package
  local has_is_deleted has_gmt_deleted has_status has_id delete_body batch_delete_body query_deleted_condition query_deleted_inline_condition update_wrapper_deleted_line commented_update_wrapper_deleted_line enable_impl_block batch_status_impl_block update_copy_id_line
  entity_var="$(lower_first "$ENTITY_NAME")"
  model_package="$(path_to_package "$MODEL_PATH")"
  req_package="$(path_to_package "$REQ_PATH")"
  vo_package="$(path_to_package "$VO_PATH")"
  mapper_package="$(path_to_package "$MAPPER_PATH")"
  service_package="$(path_to_package "$SERVICE_PATH")"
  service_impl_package="$(path_to_package "$SERVICE_IMPL_PATH")"
  has_is_deleted="false"
  has_gmt_deleted="false"
  has_status="false"
  has_id="false"

  if column_exists "is_deleted"; then
    has_is_deleted="true"
  fi
  if column_exists "gmt_deleted"; then
    has_gmt_deleted="true"
  fi
  if column_exists "status"; then
    has_status="true"
  fi
  if column_exists "id"; then
    has_id="true"
  fi

  if [ "$has_is_deleted" = "true" ]; then
    query_deleted_condition='
                .eq("is_deleted", 0)'
    query_deleted_inline_condition='.eq("is_deleted", 0)'
    update_wrapper_deleted_line=$'\n''        updateWrapper.eq("is_deleted", 0);'
    commented_update_wrapper_deleted_line=$'\n''//            updateWrapper.eq("is_deleted", 0);'
  else
    query_deleted_condition=''
    query_deleted_inline_condition=''
    update_wrapper_deleted_line=''
    commented_update_wrapper_deleted_line=''
  fi

  if [ "$has_is_deleted" = "true" ]; then
    delete_body='        getByPkIdOrThrow(pkId);
        '"${ENTITY_NAME}"' updateEntity = new '"${ENTITY_NAME}"'();
        updateEntity.setPkId(pkId);'
    delete_body="${delete_body}"$'\n''        updateEntity.setIsDeleted(1);'
    if [ "$has_gmt_deleted" = "true" ]; then
      delete_body="${delete_body}"$'\n''        updateEntity.setGmtDeleted(LocalDateTime.now());'
    fi
    delete_body="${delete_body}"$'\n''        boolean result = this.updateById(updateEntity);'
    delete_body="${delete_body}"$'\n''        log.info("'"${DISPLAY_NAME}"'删除完成, pkId={}, result={}", pkId, result);'
    delete_body="${delete_body}"$'\n''        // 当前表包含 is_deleted 字段，默认启用软删除。'
    delete_body="${delete_body}"$'\n''        // 如业务明确需要物理删除，可按需切换为硬删除：'
    delete_body="${delete_body}"$'\n''        // boolean result = this.removeById(pkId);'
    delete_body="${delete_body}"$'\n''        return result;'
  else
    delete_body='        getByPkIdOrThrow(pkId);
        boolean result = this.removeById(pkId);
        if (!result) {
            throw new RuntimeException("'"${DISPLAY_NAME}"'删除失败");
        }
        log.info("'"${DISPLAY_NAME}"'删除完成, pkId={}, result={}", pkId, result);
        // 当前表未包含 is_deleted 字段，因此默认启用硬删除。
        // 如后续表结构补充了逻辑删除字段，也可改为软删除：
        // '"${ENTITY_NAME}"' updateEntity = new '"${ENTITY_NAME}"'();
        // updateEntity.setPkId(pkId);
        // updateEntity.setIsDeleted(1);
        // updateEntity.setGmtDeleted(LocalDateTime.now());
        // boolean result = this.updateById(updateEntity);
        return result;'
  fi
  if [ "$has_is_deleted" = "true" ]; then
    batch_delete_body='        validateBatchPkIdList(pkIdList);
        List<'"${ENTITY_NAME}"'> dbList = listByPkIdsOrThrow(pkIdList);
        '"${ENTITY_NAME}"' updateEntity = new '"${ENTITY_NAME}"'();'
    batch_delete_body="${batch_delete_body}"$'\n''        updateEntity.setIsDeleted(1);'
    if [ "$has_gmt_deleted" = "true" ]; then
      batch_delete_body="${batch_delete_body}"$'\n''        updateEntity.setGmtDeleted(LocalDateTime.now());'
    fi
    batch_delete_body="${batch_delete_body}"$'\n''        QueryWrapper<'"${ENTITY_NAME}"'> updateWrapper = new QueryWrapper<>();'
    batch_delete_body="${batch_delete_body}"$'\n''        updateWrapper.in("pk_id", pkIdList);'"${update_wrapper_deleted_line}"
    batch_delete_body="${batch_delete_body}"$'\n''        boolean result = this.update(updateEntity, updateWrapper);'
    batch_delete_body="${batch_delete_body}"$'\n''        if (!result) {'
    batch_delete_body="${batch_delete_body}"$'\n''            throw new RuntimeException("'"${DISPLAY_NAME}"'批量删除失败");'
    batch_delete_body="${batch_delete_body}"$'\n''        }'
    batch_delete_body="${batch_delete_body}"$'\n''        log.info("'"${DISPLAY_NAME}"'批量删除完成, size={}, result={}", dbList.size(), result);'
    batch_delete_body="${batch_delete_body}"$'\n''        // 当前表包含 is_deleted 字段，默认启用软删除。'
    batch_delete_body="${batch_delete_body}"$'\n''        // 如业务明确需要物理删除，可按需切换为硬删除：'
    batch_delete_body="${batch_delete_body}"$'\n''        // boolean result = this.removeByIds(pkIdList);'
    batch_delete_body="${batch_delete_body}"$'\n''        return true;'
  else
    batch_delete_body='        validateBatchPkIdList(pkIdList);
        listByPkIdsOrThrow(pkIdList);
        boolean result = this.removeByIds(pkIdList);
        if (!result) {
            throw new RuntimeException("'"${DISPLAY_NAME}"'批量删除失败");
        }
        log.info("'"${DISPLAY_NAME}"'批量删除完成, size={}, result={}", pkIdList.size(), result);
        // 当前表未包含 is_deleted 字段，因此默认启用硬删除。
        // 如后续表结构补充了逻辑删除字段，也可改为软删除：
        // '"${ENTITY_NAME}"' updateEntity = new '"${ENTITY_NAME}"'();
        // updateEntity.setIsDeleted(1);
        // updateEntity.setGmtDeleted(LocalDateTime.now());
        // QueryWrapper<'"${ENTITY_NAME}"'> updateWrapper = new QueryWrapper<>();
        // updateWrapper.in("pk_id", pkIdList);
        // boolean result = this.update(updateEntity, updateWrapper);
        return true;'
  fi
  if [ "$has_status" = "true" ]; then
    enable_impl_block="
    /**
     * [CRUD-CODEGEN] 本方法由 CRUD-CODEGEN 脚手架生成，请结合实际业务调整。
     *
     * 启用或禁用${DISPLAY_NAME}
     *
     * @param pkId 主键ID
     * @return 是否执行成功
     */
    @Override
    public boolean enable(long pkId) {
        try {
            ${ENTITY_NAME} entity = getByPkIdOrThrow(pkId);
            ${ENTITY_NAME} updateEntity = new ${ENTITY_NAME}();
            updateEntity.setPkId(entity.getPkId());
            updateEntity.setStatus(entity.getStatus() != null && entity.getStatus() == 1 ? 0 : 1);
            boolean result = this.updateById(updateEntity);
            log.info(\"${DISPLAY_NAME}启用状态切换完成, pkId={}, targetStatus={}, result={}\", pkId, updateEntity.getStatus(), result);
            return result;
        } catch (RuntimeException e) {
            log.error(\"${DISPLAY_NAME}启用状态切换失败, pkId={}\", pkId, e);
            throw e;
        } catch (Exception e) {
            log.error(\"${DISPLAY_NAME}启用状态切换异常, pkId={}\", pkId, e);
            throw new RuntimeException(\"${DISPLAY_NAME}启用状态切换失败\", e);
        }
    }"
    batch_status_impl_block="
    /**
     * [CRUD-CODEGEN] 本方法由 CRUD-CODEGEN 脚手架生成，请结合实际业务调整。
     *
     * 批量变更${DISPLAY_NAME}状态
     *
     * @param pkIdList 主键ID列表
     * @param status 目标状态
     * @return 是否执行成功
     */
    @Override
    @Transactional(rollbackFor = Exception.class)
    public boolean batchStatus(List<Long> pkIdList, Integer status) {
        try {
            validateBatchPkIdList(pkIdList);
            if (status == null) {
                throw new RuntimeException(\"${DISPLAY_NAME}状态不能为空\");
            }
            if (status != 0 && status != 1 && status != 9) {
                throw new RuntimeException(\"${DISPLAY_NAME}状态仅支持 0/1/9\");
            }
            List<${ENTITY_NAME}> dbList = listByPkIdsOrThrow(pkIdList);
            ${ENTITY_NAME} updateEntity = new ${ENTITY_NAME}();
            updateEntity.setStatus(status);
            QueryWrapper<${ENTITY_NAME}> updateWrapper = new QueryWrapper<>();
            updateWrapper.in(\"pk_id\", pkIdList);${update_wrapper_deleted_line}
            boolean result = this.update(updateEntity, updateWrapper);
            if (!result) {
                throw new RuntimeException(\"${DISPLAY_NAME}批量状态变更失败\");
            }
            log.info(\"${DISPLAY_NAME}批量状态变更完成, size={}, status={}, result={}\", dbList.size(), status, result);
            return true;
        } catch (RuntimeException e) {
            log.error(\"${DISPLAY_NAME}批量状态变更失败, size={}, status={}\", pkIdList == null ? 0 : pkIdList.size(), status, e);
            throw e;
        } catch (Exception e) {
            log.error(\"${DISPLAY_NAME}批量状态变更异常, size={}, status={}\", pkIdList == null ? 0 : pkIdList.size(), status, e);
            throw new RuntimeException(\"${DISPLAY_NAME}批量状态变更失败\", e);
        }
    }"
  else
    enable_impl_block='
//    当前表无 status 字段，不生成 enable 方法
//    /**
//     * [CRUD-CODEGEN] 本方法由 CRUD-CODEGEN 脚手架生成，请结合实际业务调整。
//     *
//     * 启用或禁用'"${DISPLAY_NAME}"'
//     *
//     * @param pkId 主键ID
//     * @return 是否执行成功
//     */
//    @Override
//    public boolean enable(long pkId) {
//        try {
//            '"${ENTITY_NAME}"' entity = getByPkIdOrThrow(pkId);
//            '"${ENTITY_NAME}"' updateEntity = new '"${ENTITY_NAME}"'();
//            updateEntity.setPkId(entity.getPkId());
//            updateEntity.setStatus(entity.getStatus() != null && entity.getStatus() == 1 ? 0 : 1);
//            boolean result = this.updateById(updateEntity);
//            log.info("'"${DISPLAY_NAME}"'启用状态切换完成, pkId={}, targetStatus={}, result={}", pkId, updateEntity.getStatus(), result);
//            return result;
//        } catch (RuntimeException e) {
//            log.error("'"${DISPLAY_NAME}"'启用状态切换失败, pkId={}", pkId, e);
//            throw e;
//        } catch (Exception e) {
//            log.error("'"${DISPLAY_NAME}"'启用状态切换异常, pkId={}", pkId, e);
//            throw new RuntimeException("'"${DISPLAY_NAME}"'启用状态切换失败", e);
//        }
//    }'
    batch_status_impl_block='
//    当前表无 status 字段，不生成批量状态变更方法
//    /**
//     * [CRUD-CODEGEN] 本方法由 CRUD-CODEGEN 脚手架生成，请结合实际业务调整。
//     *
//     * 批量变更'"${DISPLAY_NAME}"'状态
//     *
//     * @param pkIdList 主键ID列表
//     * @param status 目标状态
//     * @return 是否执行成功
//     */
//    @Override
//    @Transactional(rollbackFor = Exception.class)
//    public boolean batchStatus(List<Long> pkIdList, Integer status) {
//        try {
//            validateBatchPkIdList(pkIdList);
//            if (status == null) {
//                throw new RuntimeException("'"${DISPLAY_NAME}"'状态不能为空");
//            }
//            if (status != 0 && status != 1 && status != 9) {
//                throw new RuntimeException("'"${DISPLAY_NAME}"'状态仅支持 0/1/9");
//            }
//            List<'"${ENTITY_NAME}"'> dbList = listByPkIdsOrThrow(pkIdList);
//            '"${ENTITY_NAME}"' updateEntity = new '"${ENTITY_NAME}"'();
//            updateEntity.setStatus(status);
//            QueryWrapper<'"${ENTITY_NAME}"'> updateWrapper = new QueryWrapper<>();
//            updateWrapper.in("pk_id", pkIdList);'"${commented_update_wrapper_deleted_line}"'
//            boolean result = this.update(updateEntity, updateWrapper);
//            if (!result) {
//                throw new RuntimeException("'"${DISPLAY_NAME}"'批量状态变更失败");
//            }
//            log.info("'"${DISPLAY_NAME}"'批量状态变更完成, size={}, status={}, result={}", dbList.size(), status, result);
//            return true;
//        } catch (RuntimeException e) {
//            log.error("'"${DISPLAY_NAME}"'批量状态变更失败, size={}, status={}", pkIdList == null ? 0 : pkIdList.size(), status, e);
//            throw e;
//        } catch (Exception e) {
//            log.error("'"${DISPLAY_NAME}"'批量状态变更异常, size={}, status={}", pkIdList == null ? 0 : pkIdList.size(), status, e);
//            throw new RuntimeException("'"${DISPLAY_NAME}"'批量状态变更失败", e);
//        }
//    }'
  fi
  if [ "$has_id" = "true" ]; then
    update_copy_id_line='
            entity.setId(existing.getId());'
  else
    update_copy_id_line=''
  fi
  cat <<EOF
package ${BASE_PACKAGE}.${service_impl_package};

import com.baomidou.mybatisplus.core.conditions.query.QueryWrapper;
import com.baomidou.mybatisplus.extension.service.impl.ServiceImpl;
import com.github.pagehelper.PageHelper;
import com.github.pagehelper.PageInfo;
import ${BASE_PACKAGE}.${model_package}.${ENTITY_NAME};
import ${BASE_PACKAGE}.${req_package}.${ENTITY_NAME}CreateReq;
import ${BASE_PACKAGE}.${req_package}.${ENTITY_NAME}PageReq;
import ${BASE_PACKAGE}.${req_package}.${ENTITY_NAME}UpdateReq;
import ${BASE_PACKAGE}.${vo_package}.${ENTITY_NAME}ShowVO;
import ${BASE_PACKAGE}.${vo_package}.${ENTITY_NAME}VO;
