render_xml_where_block() {
  local has_deleted="false"
  local xml_comment
  if column_exists "is_deleted"; then
    has_deleted="true"
  fi

  if [ "$has_deleted" = "true" ]; then
    cat <<'EOF'
        b.is_deleted = 0
EOF
  else
    cat <<'EOF'
        1 = 1
EOF
  fi

  while IFS='|' read -r column field java_type raw_type comment nullable primary auto size; do
    if is_page_hidden_field "$column"; then
      continue
    fi
    xml_comment="$(escape_xml_comment "$comment")"
    if [ "$column" = "gmt_created" ] || [ "$column" = "gmt_modified" ]; then
      cat <<EOF
        <!-- ${xml_comment}开始 -->
        <if test="${field}Start != null">
            AND b.${column} <![CDATA[>=]]> #{${field}Start}
        </if>
        <!-- ${xml_comment}结束 -->
        <if test="${field}End != null">
            AND b.${column} <![CDATA[<=]]> #{${field}End}
        </if>
EOF
      continue
    fi
    if is_string_type "$java_type" && is_name_like_field "$column" "$field"; then
      cat <<EOF
        <!-- ${xml_comment} -->
        <if test="${field} != null and ${field}.trim() != ''">
            AND b.${column} LIKE CONCAT('%', #{${field}}, '%')
        </if>
EOF
    elif is_string_type "$java_type" && is_code_field "$column" "$field"; then
      cat <<EOF
        <!-- ${xml_comment} -->
        <if test="${field} != null and ${field}.trim() != ''">
            AND b.${column} = #{${field}}
        </if>
EOF
    elif is_string_type "$java_type"; then
      cat <<EOF
        <!-- ${xml_comment} -->
        <if test="${field} != null and ${field}.trim() != ''">
            AND b.${column} = #{${field}}
        </if>
EOF
    else
      cat <<EOF
        <!-- ${xml_comment} -->
        <if test="${field} != null">
            AND b.${column} = #{${field}}
        </if>
EOF
    fi
  done < "$FIELDS_FILE"
}

render_mapper_xml() {
  local order_by req_package vo_package mapper_package
  order_by="$(resolve_order_by)"
  req_package="$(path_to_package "$REQ_PATH")"
  vo_package="$(path_to_package "$VO_PATH")"
  mapper_package="$(path_to_package "$MAPPER_PATH")"
  cat <<EOF
<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="${BASE_PACKAGE}.${mapper_package}.${ENTITY_NAME}Mapper">

    <sql id="baseColumns">
EOF
  while IFS='|' read -r column field java_type raw_type comment nullable primary auto size; do
    echo "        b.${column},"
  done < "$FIELDS_FILE" | sed '$ s/,$//'
  cat <<EOF
    </sql>

    <sql id="baseWhere">
EOF
  render_xml_where_block
  cat <<EOF
    </sql>

    <select id="pageAll"
            parameterType="${BASE_PACKAGE}.${req_package}.${ENTITY_NAME}PageReq"
            resultType="${BASE_PACKAGE}.${vo_package}.${ENTITY_NAME}VO">
        SELECT
        <include refid="baseColumns"/>
        FROM ${TABLE_NAME} b
        WHERE
        <include refid="baseWhere"/>
        ORDER BY ${order_by}
    </select>

    <select id="all"
            parameterType="${BASE_PACKAGE}.${req_package}.${ENTITY_NAME}PageReq"
            resultType="${BASE_PACKAGE}.${vo_package}.${ENTITY_NAME}VO">
        SELECT
        <include refid="baseColumns"/>
        FROM ${TABLE_NAME} b
        WHERE
        <include refid="baseWhere"/>
        ORDER BY ${order_by}
    </select>
</mapper>
EOF
}

