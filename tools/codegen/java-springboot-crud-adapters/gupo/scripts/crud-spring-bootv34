#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="${PWD}"

BASE_PACKAGE=""
BASE_PACKAGE_SOURCE=""
JAVA_BASE_DIR=""
RESOURCES_BASE_DIR=""
ENTITY_NAME=""
MODULE_PATH=""
TABLE_NAME=""
ROUTE_PATH=""
DISPLAY_NAME=""
DDL=""
FORCE="false"
FORCE_TOKEN=""
PREVIEW="false"
MODEL_PATH=""
REQ_PATH=""
VO_PATH=""
CONTROLLER_PATH=""
SERVICE_PATH=""
SERVICE_IMPL_PATH=""
MAPPER_PATH=""
XML_PATH=""
APPENDED_FILES=()
MAX_BATCH_SIZE=100
FORCE_TOKEN_STORE=""
FORCE_TOKEN_VERIFIED="false"

if [ -t 1 ]; then
  COLOR_RESET=$'\033[0m'
  COLOR_BOLD=$'\033[1m'
  COLOR_RED=$'\033[31m'
  COLOR_GREEN=$'\033[32m'
  COLOR_YELLOW=$'\033[33m'
  COLOR_CYAN=$'\033[36m'
else
  COLOR_RESET=""
  COLOR_BOLD=""
  COLOR_RED=""
  COLOR_GREEN=""
  COLOR_YELLOW=""
  COLOR_CYAN=""
fi

FIELDS_FILE="$(mktemp)"
trap 'rm -f "$FIELDS_FILE"' EXIT

usage() {
  cat <<'EOF'
用法:
  bash skill-run-crud-codegen-boot34.sh \
    [--project-root /path/to/project] \
    [--base-package com.groupds.gupo.saas] \
    [--java-base-dir src/main/java/com/groupds/gupo/saas] \
    [--resources-base-dir src/main/resources/mapper] \
    --entity-name TagDefine \
    --module-path tag \
    --route-path /api/v1/saas/admin/tag-define \
    --display-name 标签定义 \
    --ddl "CREATE TABLE ..." \
    [--table-name plat_tag_define] \
    [--controller-path controller/tag] \
    [--req-path entity/req/tag] \
    [--vo-path entity/vo/tag] \
    [--model-path entity/model] \
    [--service-path service] \
    [--service-impl-path service/impl] \
    [--mapper-path mapper] \
    [--xml-path .] \
    [--preview] \
    [--force] \
    [--force-token 8X4P7Q]
EOF
}

require_non_empty() {
  local name="$1"
  local value="$2"
  if [ -z "$value" ]; then
    echo "参数不能为空: $name" >&2
    exit 1
  fi
}

normalize_project_root() {
  if [ ! -d "$PROJECT_ROOT" ]; then
    echo "--project-root 指向的目录不存在: $PROJECT_ROOT" >&2
    exit 1
  fi
  PROJECT_ROOT="$(cd "$PROJECT_ROOT" && pwd)"
  FORCE_TOKEN_STORE="${PROJECT_ROOT}/.crud-codegen-force-token"
}

validate_project_root() {
  if [ ! -f "${PROJECT_ROOT}/pom.xml" ]; then
    echo "项目根目录校验失败: ${PROJECT_ROOT} 下未找到 pom.xml" >&2
    exit 1
  fi
  if [ ! -d "${PROJECT_ROOT}/src/main/java" ]; then
    echo "项目根目录校验失败: ${PROJECT_ROOT} 下未找到 src/main/java" >&2
    exit 1
  fi
}

validate_base_package() {
  if [[ ! "$BASE_PACKAGE" =~ ^[a-z][a-z0-9]*(\.[a-z][a-z0-9]*)*$ ]]; then
    echo "--base-package 格式不正确，例如 com.groupds.gupo.saas" >&2
    exit 1
  fi
}

apply_default_base_dirs() {
  if [ -z "$JAVA_BASE_DIR" ]; then
    JAVA_BASE_DIR="src/main/java"
  fi
  if [ -z "$RESOURCES_BASE_DIR" ]; then
    RESOURCES_BASE_DIR="src/main/resources/mapper"
  fi
}

infer_base_package_from_java_base_dir() {
  local normalized_java_base_dir
  normalized_java_base_dir="${JAVA_BASE_DIR#./}"
  normalized_java_base_dir="${normalized_java_base_dir%/}"

  if [[ ! "$normalized_java_base_dir" =~ ^src/main/java/([a-z][a-z0-9]*(/[a-z][a-z0-9]*)*)$ ]]; then
    return 1
  fi

  printf '%s' "${BASH_REMATCH[1]//\//.}"
}

discover_base_package_from_project() {
  local src_dir package_file package_line package_name discovered_package
  src_dir="${PROJECT_ROOT}/src/main/java"
  [ -d "$src_dir" ] || return 1

  package_file="$(find "$src_dir" -type f -name '*.java' | sort | while IFS= read -r file_path; do
    if grep -q '@SpringBootApplication' "$file_path"; then
      printf '%s\n' "$file_path"
      break
    fi
  done)"

  if [ -z "$package_file" ]; then
    package_file="$(find "$src_dir" -type f -name '*.java' | sort | head -n 1)"
  fi

  if [ -n "$package_file" ] && [ -f "$package_file" ]; then
    package_line="$(sed -nE 's/^[[:space:]]*package[[:space:]]+([a-z][a-z0-9]*(\.[a-z][a-z0-9]*)*)[[:space:]]*;.*/\1/p' "$package_file" | head -n 1)"
    if [ -n "$package_line" ]; then
      printf '%s' "$package_line"
      return 0
    fi
  fi

  discovered_package="${src_dir}"
  while true; do
    local child_dirs_count next_dir
    child_dirs_count="$(find "$discovered_package" -mindepth 1 -maxdepth 1 -type d | wc -l | tr -d ' ')"
    if [ "$child_dirs_count" != "1" ]; then
      break
    fi
    next_dir="$(find "$discovered_package" -mindepth 1 -maxdepth 1 -type d | head -n 1)"
    if [[ ! "$(basename "$next_dir")" =~ ^[a-z][a-z0-9]*$ ]]; then
      break
    fi
    discovered_package="$next_dir"
  done

  if [ "$discovered_package" = "$src_dir" ]; then
    return 1
  fi

  package_name="${discovered_package#"$src_dir/"}"
  package_name="${package_name//\//.}"
  if [[ "$package_name" =~ ^[a-z][a-z0-9]*(\.[a-z][a-z0-9]*)*$ ]]; then
    printf '%s' "$package_name"
    return 0
  fi

  return 1
}

resolve_base_package() {
  local inferred_base_package=""
  local discovered_base_package=""

  if inferred_base_package="$(infer_base_package_from_java_base_dir)"; then
    :
  else
    inferred_base_package=""
  fi

  if discovered_base_package="$(discover_base_package_from_project)"; then
    :
  else
    discovered_base_package=""
  fi

  if [ -n "$BASE_PACKAGE" ]; then
    if [ -n "$inferred_base_package" ] && [ "$BASE_PACKAGE" != "$inferred_base_package" ]; then
      echo "--base-package 与 --java-base-dir 推导结果不一致: ${BASE_PACKAGE} != ${inferred_base_package}" >&2
      exit 1
    fi
    if [ -n "$discovered_base_package" ] && [ "$BASE_PACKAGE" != "$discovered_base_package" ]; then
      echo "--base-package 与项目自动发现结果不一致: ${BASE_PACKAGE} != ${discovered_base_package}" >&2
      exit 1
    fi
    BASE_PACKAGE_SOURCE="手动入参"
    return 0
  fi

  if [ -n "$inferred_base_package" ]; then
    BASE_PACKAGE="$inferred_base_package"
    BASE_PACKAGE_SOURCE="自动推导（来自 --java-base-dir=${JAVA_BASE_DIR}）"
    return 0
  fi

  if [ -n "$discovered_base_package" ]; then
    BASE_PACKAGE="$discovered_base_package"
    BASE_PACKAGE_SOURCE="自动发现（来自 ${PROJECT_ROOT}/src/main/java）"
    return 0
  fi

  echo "未传 --base-package，且无法从 --java-base-dir 推导或从项目自动发现基础包名" >&2
  echo "当前 --java-base-dir: ${JAVA_BASE_DIR}" >&2
  echo "请传入 --base-package，或将 --java-base-dir 设为 src/main/java/com/example/demo 这类路径" >&2
  exit 1
}

validate_entity_name() {
  if [[ ! "$ENTITY_NAME" =~ ^[A-Z][A-Za-z0-9]*$ ]]; then
    echo "--entity-name 必须是大驼峰命名，例如 TagDefine" >&2
    exit 1
  fi
}

validate_path_value() {
  local flag_name="$1"
  local value="$2"
  if [[ ! "$value" =~ ^[a-z]+(_[a-z0-9]+)*(\/[a-z]+(_[a-z0-9]+)*)*$ ]]; then
    echo "${flag_name} 必须使用小写下划线目录格式，例如 tag、merchant_bundle 或 disease/scene_config" >&2
    exit 1
  fi
}

validate_route_path() {
  if [[ ! "$ROUTE_PATH" =~ ^/ ]]; then
    echo "--route-path 必须以 / 开头" >&2
    exit 1
  fi
}

java_base_path() {
  printf '%s/%s' "$PROJECT_ROOT" "$JAVA_BASE_DIR"
}

xml_base_path() {
  printf '%s/%s' "$PROJECT_ROOT" "$RESOURCES_BASE_DIR"
}

display_path() {
  local input="$1"
  if [[ "$input" == "$PROJECT_ROOT/"* ]]; then
    printf '%s' "${input#"$PROJECT_ROOT/"}"
  else
    printf '%s' "$input"
  fi
}

green_line() {
  printf '%b%s%b\n' "${COLOR_GREEN}" "$1" "${COLOR_RESET}"
}

red_bold_line() {
  printf '%b%b%s%b\n' "${COLOR_BOLD}" "${COLOR_RED}" "$1" "${COLOR_RESET}"
}

cyan_bold_line() {
  printf '%b%b%s%b\n' "${COLOR_BOLD}" "${COLOR_CYAN}" "$1" "${COLOR_RESET}"
}

yellow_bold_line() {
  printf '%b%b%s%b\n' "${COLOR_BOLD}" "${COLOR_YELLOW}" "$1" "${COLOR_RESET}"
}

collect_target_files() {
  local java_base xml_base
  java_base="$(java_base_path)"
  xml_base="$(xml_base_path)"

  printf '%s\n' "$java_base/${MODEL_PATH}/${ENTITY_NAME}.java"
  printf '%s\n' "$java_base/${REQ_PATH}/${ENTITY_NAME}CreateReq.java"
  printf '%s\n' "$java_base/${REQ_PATH}/${ENTITY_NAME}UpdateReq.java"
  printf '%s\n' "$java_base/${REQ_PATH}/${ENTITY_NAME}BatchDeleteReq.java"
  if column_exists "status"; then
    printf '%s\n' "$java_base/${REQ_PATH}/${ENTITY_NAME}BatchStatusReq.java"
  fi
  printf '%s\n' "$java_base/${REQ_PATH}/${ENTITY_NAME}PageReq.java"
  printf '%s\n' "$java_base/${VO_PATH}/${ENTITY_NAME}VO.java"
  printf '%s\n' "$java_base/${VO_PATH}/${ENTITY_NAME}ShowVO.java"
  printf '%s\n' "$java_base/${MAPPER_PATH}/${ENTITY_NAME}Mapper.java"
  if [ -n "$XML_PATH" ] && [ "$XML_PATH" != "." ]; then
    printf '%s\n' "$xml_base/${XML_PATH}/${ENTITY_NAME}Mapper.xml"
  else
    printf '%s\n' "$xml_base/${ENTITY_NAME}Mapper.xml"
  fi
  printf '%s\n' "$java_base/${SERVICE_PATH}/${ENTITY_NAME}Service.java"
  printf '%s\n' "$java_base/${SERVICE_IMPL_PATH}/${ENTITY_NAME}ServiceImpl.java"
  printf '%s\n' "$java_base/${CONTROLLER_PATH}/${ENTITY_NAME}Controller.java"
}

model_target_file() {
  printf '%s/%s/%s.java' "$(java_base_path)" "$MODEL_PATH" "$ENTITY_NAME"
}

is_model_file_path() {
  local file_path="$1"
  [ "$file_path" = "$(model_target_file)" ]
}

collect_existing_target_files() {
  local target_file
  while IFS= read -r target_file; do
    [ -f "$target_file" ] && printf '%s\n' "$target_file"
  done < <(collect_target_files)
  return 0
}

generate_force_token() {
  printf '%s' "$(date '+%Y%m%d%H%M%S')-${ENTITY_NAME}-${TABLE_NAME:-none}-${ROUTE_PATH}-${RANDOM:-0}-$$" \
    | cksum \
    | awk '{print toupper(substr($1, 1, 8))}'
}

current_force_fingerprint() {
  {
    printf '%s\n' "$BASE_PACKAGE"
    printf '%s\n' "$JAVA_BASE_DIR"
    printf '%s\n' "$RESOURCES_BASE_DIR"
    printf '%s\n' "$ENTITY_NAME"
    printf '%s\n' "$MODULE_PATH"
    printf '%s\n' "$TABLE_NAME"
    printf '%s\n' "$ROUTE_PATH"
    printf '%s\n' "$DISPLAY_NAME"
    collect_existing_target_files | sort
  } | cksum | awk '{print $1}'
}

stored_force_token() {
  [ -f "$FORCE_TOKEN_STORE" ] || return 0
  awk -F'=' '$1 == "token" { print $2; exit }' "$FORCE_TOKEN_STORE"
}

stored_force_fingerprint() {
  [ -f "$FORCE_TOKEN_STORE" ] || return 0
  awk -F'=' '$1 == "fingerprint" { print $2; exit }' "$FORCE_TOKEN_STORE"
}

persist_force_token() {
  local token="$1"
  local fingerprint="$2"
  {
    printf 'token=%s\n' "$token"
    printf 'fingerprint=%s\n' "$fingerprint"
    printf 'created_at=%s\n' "$(append_timestamp)"
  } > "$FORCE_TOKEN_STORE"
}

invalidate_force_token() {
  rm -f "$FORCE_TOKEN_STORE"
}

print_force_token_prompt() {
  local token="$1"
  shift
  local existing_files=("$@")
  local file_path file_count java_count xml_count other_count
  file_count="${#existing_files[@]}"
  java_count=0
  xml_count=0
  other_count=0

  for file_path in "${existing_files[@]}"; do
    case "$file_path" in
      *.java) java_count=$((java_count + 1)) ;;
      *.xml) xml_count=$((xml_count + 1)) ;;
      *) other_count=$((other_count + 1)) ;;
    esac
  done

  echo
  red_bold_line "安全覆盖确认"
  yellow_bold_line "  本次将覆盖 ${file_count} 个已存在文件"
  printf '  覆盖统计: %s 个 Java 文件' "$java_count"
  if [ "$xml_count" -gt 0 ]; then
    printf ' + %s 个 XML 文件' "$xml_count"
  fi
  if [ "$other_count" -gt 0 ]; then
    printf ' + %s 个其他文件' "$other_count"
  fi
  printf '\n'
  echo "  本次检测到以下目标文件已存在。"
  echo "  为避免误覆盖，当前命令不会立即执行覆盖写入。"
  echo "  如确认需要继续，请保留原参数并追加一次性安全码重新执行。"
  echo "  安全码仅对当前这批待覆盖文件有效，成功覆盖后立即失效。"
  echo
  printf '%b覆盖路径%b\n' "${COLOR_BOLD}" "${COLOR_RESET}"
  for file_path in "${existing_files[@]}"; do
    printf '%b%b  %s%b\n' "${COLOR_BOLD}" "${COLOR_RED}" "$(display_path "$file_path")" "${COLOR_RESET}"
  done
  echo
  printf '%b%b一次性安全码: %s%b\n' "${COLOR_BOLD}" "${COLOR_YELLOW}" "$token" "${COLOR_RESET}"
  echo "  请在确认无误后，使用以下附加参数重新执行命令："
  printf '  --force-token %s\n' "$token"
}

enforce_force_token_if_needed() {
  if [ "$FORCE" != "true" ]; then
    return 0
  fi
  if [ "$PREVIEW" = "true" ]; then
    return 0
  fi

  local existing_files=()
  local target_file
  while IFS= read -r target_file; do
    [ -n "$target_file" ] && existing_files+=("$target_file")
  done < <(collect_existing_target_files)

  if [ "${#existing_files[@]}" -eq 0 ]; then
    return 0
  fi

  local fingerprint stored_token stored_fingerprint fresh_token
  fingerprint="$(current_force_fingerprint)"

  if [ -n "$FORCE_TOKEN" ]; then
    stored_token="$(stored_force_token)"
    stored_fingerprint="$(stored_force_fingerprint)"
    if [ -n "$stored_token" ] && [ "$FORCE_TOKEN" = "$stored_token" ] && [ "$fingerprint" = "$stored_fingerprint" ]; then
      FORCE_TOKEN_VERIFIED="true"
      return
    fi

    invalidate_force_token
    fresh_token="$(generate_force_token)"
    persist_force_token "$fresh_token" "$fingerprint"
    echo
    red_bold_line "安全码校验未通过"
    echo "  当前提供的 --force-token 无效、已失效，或与本次待覆盖文件不匹配。"
    echo "  脚手架本次未执行覆盖，请使用下面的新安全码重新确认。"
    print_force_token_prompt "$fresh_token" "${existing_files[@]}"
    exit 1
  fi

  fresh_token="$(generate_force_token)"
  persist_force_token "$fresh_token" "$fingerprint"
  print_force_token_prompt "$fresh_token" "${existing_files[@]}"
  exit 0
}

lower_first() {
  local input="$1"
  printf '%s%s' "$(tr '[:upper:]' '[:lower:]' <<< "${input:0:1}")" "${input:1}"
}

append_timestamp() {
  date '+%Y-%m-%d %H:%M:%S'
}

append_marker() {
  printf '%s' " //----------------------------------- $(append_timestamp) sh 追加的代码-------------------------------------------"
}

path_to_package() {
  local input="$1"
  printf '%s' "${input//\//.}"
}

snake_to_camel() {
  local input="$1"
  awk -F'_' '{
    out=$1;
    for (i=2; i<=NF; i++) {
      out=out toupper(substr($i,1,1)) substr($i,2);
    }
    print out;
  }' <<< "$input"
}

escape_java() {
  local input="${1:-}"
  input="${input//\\/\\\\}"
  input="${input//\"/\\\"}"
  printf '%s' "$input"
}

escape_xml_comment() {
  local input="${1:-}"
  input="${input//--/- -}"
  input="${input//</＜}"
  input="${input//>/＞}"
  printf '%s' "$input"
}

normalize_sql_type() {
  local raw_type
  raw_type="$(tr '[:upper:]' '[:lower:]' <<< "$1")"
  raw_type="$(sed -E 's/[[:space:]]+unsigned//g; s/[[:space:]]+zerofill//g; s/[[:space:]]+character set[[:space:]]+[a-z0-9_]+//g; s/[[:space:]]+charset[[:space:]]+[a-z0-9_]+//g; s/[[:space:]]+collate[[:space:]]+[a-z0-9_]+//g; s/[[:space:]]+/ /g; s/^[[:space:]]+//; s/[[:space:]]+$//' <<< "$raw_type")"
  printf '%s' "$raw_type"
}

is_string_type() {
  [ "$1" = "String" ]
}

is_date_type() {
  [ "$1" = "LocalDateTime" ]
}

is_decimal_type() {
  [ "$1" = "BigDecimal" ] || [ "$1" = "Double" ] || [ "$1" = "Float" ]
}

default_example() {
  local java_type="$1"
  case "$java_type" in
    Long|Integer) printf '1' ;;
    BigDecimal|Double|Float) printf '0.00' ;;
    Boolean) printf 'true' ;;
    LocalDateTime) printf '2026-01-01 00:00:00' ;;
    *) printf '示例值' ;;
  esac
}

map_sql_type() {
  local raw_type
  raw_type="$(normalize_sql_type "$1")"
  case "$raw_type" in
    bigint* ) printf 'Long' ;;
    tinyint*|smallint*|mediumint*|int*|integer* ) printf 'Integer' ;;
    decimal*|numeric* ) printf 'BigDecimal' ;;
    double* ) printf 'Double' ;;
    float* ) printf 'Float' ;;
    datetime*|timestamp*|date*|time* ) printf 'LocalDateTime' ;;
    bit*|boolean ) printf 'Boolean' ;;
    char*|varchar*|tinytext*|text*|mediumtext*|longtext*|json|enum*|set* ) printf 'String' ;;
    * ) printf 'String' ;;
  esac
}

extract_size() {
  local raw_type="$1"
  sed -nE 's/^[^(]+\(([0-9]+).*/\1/p' <<< "$(normalize_sql_type "$raw_type")"
}

extract_comment_from_line() {
  local line="$1"
  LINE_FOR_COMMENT="$line" LC_ALL=C LANG=C perl -e '
    my $line = $ENV{LINE_FOR_COMMENT} // q{};
    my $quote = chr(39);
    if ($line =~ /COMMENT\s+\Q$quote\E((?:[^\Q$quote\E]|\Q$quote$quote\E)*)\Q$quote\E/i) {
      my $comment = $1;
      $comment =~ s/\Q$quote$quote\E/$quote/g;
      print $comment;
    }
  '
}

parse_args() {
  while [ $# -gt 0 ]; do
    case "$1" in
      --project-root)
        PROJECT_ROOT="${2:-}"
        shift 2
        ;;
      --base-package)
        BASE_PACKAGE="${2:-}"
        shift 2
        ;;
      --java-base-dir)
        JAVA_BASE_DIR="${2:-}"
        shift 2
        ;;
      --resources-base-dir)
        RESOURCES_BASE_DIR="${2:-}"
        shift 2
        ;;
      --entity-name)
        ENTITY_NAME="${2:-}"
        shift 2
        ;;
      --module-path|--module-key)
        MODULE_PATH="${2:-}"
        shift 2
        ;;
      --model-path)
        MODEL_PATH="${2:-}"
        shift 2
        ;;
      --req-path)
        REQ_PATH="${2:-}"
        shift 2
        ;;
      --vo-path)
        VO_PATH="${2:-}"
        shift 2
        ;;
      --controller-path)
        CONTROLLER_PATH="${2:-}"
        shift 2
        ;;
      --service-path)
        SERVICE_PATH="${2:-}"
        shift 2
        ;;
      --service-impl-path)
        SERVICE_IMPL_PATH="${2:-}"
        shift 2
        ;;
      --mapper-path)
        MAPPER_PATH="${2:-}"
        shift 2
        ;;
      --xml-path)
        XML_PATH="${2:-}"
        shift 2
        ;;
      --table-name)
        TABLE_NAME="${2:-}"
        shift 2
        ;;
      --route-path)
        ROUTE_PATH="${2:-}"
        shift 2
        ;;
      --display-name)
        DISPLAY_NAME="${2:-}"
        shift 2
        ;;
      --ddl)
        DDL="${2:-}"
        shift 2
        ;;
      --force)
        FORCE="true"
        shift
        ;;
      --force-token)
        FORCE_TOKEN="${2:-}"
        shift 2
        ;;
      --preview)
        PREVIEW="true"
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        echo "不支持的参数: $1" >&2
        usage
        exit 1
        ;;
    esac
  done
}

resolve_layer_paths() {
  if [ -z "$MODEL_PATH" ]; then
    MODEL_PATH="entity/model"
  fi
  if [ -z "$REQ_PATH" ]; then
    REQ_PATH="entity/req/${MODULE_PATH}"
  fi
  if [ -z "$VO_PATH" ]; then
    VO_PATH="entity/vo/${MODULE_PATH}"
  fi
  if [ -z "$CONTROLLER_PATH" ]; then
    CONTROLLER_PATH="controller/${MODULE_PATH}"
  fi
  if [ -z "$SERVICE_PATH" ]; then
    SERVICE_PATH="service"
  fi
  if [ -z "$SERVICE_IMPL_PATH" ]; then
    SERVICE_IMPL_PATH="service/impl"
  fi
  if [ -z "$MAPPER_PATH" ]; then
    MAPPER_PATH="mapper"
  fi
}

extract_table_name_from_ddl() {
  printf '%s' "$DDL" | tr '\r' '\n' | sed -nE "s/.*CREATE[[:space:]]+TABLE([[:space:]]+IF[[:space:]]+NOT[[:space:]]+EXISTS)?[[:space:]]+(\`?[A-Za-z0-9_]+\`?\.)?\`?([A-Za-z0-9_]+)\`?.*/\3/ip" | head -n 1
}

normalize_ddl() {
  printf '%s' "$DDL" \
    | LC_ALL=C LANG=C perl -0pe 's/\/\*![0-9]*.*?\*\///gs; s/\/\*.*?\*\///gs' \
    | sed -E '/^[[:space:]]*--/d; /^[[:space:]]*#/d' \
    | awk '
    BEGIN {
      depth = 0;
      in_quote = 0;
    }
    {
      for (i = 1; i <= length($0); i++) {
        ch = substr($0, i, 1);
        if (ch == "'"'"'") {
          in_quote = 1 - in_quote;
        }
        if (!in_quote) {
          if (ch == "(") {
            depth++;
          } else if (ch == ")") {
            depth--;
          }
        }
        printf "%s", ch;
        if (ch == "(" && depth == 1 && !in_quote) {
          printf "\n";
        }
        if (ch == "," && depth == 1 && !in_quote) {
          printf "\n";
        }
      }
      printf "\n";
    }
  '
}

extract_raw_type() {
  local line="$1"
  awk '
    {
      out = "";
      for (i = 2; i <= NF; i++) {
        token = $i;
        upper = toupper(token);
        gsub(/,$/, "", token);
        gsub(/,$/, "", upper);
        if (upper ~ /^(NOT|NULL|DEFAULT|COMMENT|PRIMARY|UNIQUE|AUTO_INCREMENT|COLLATE|CHARACTER|REFERENCES|CONSTRAINT|KEY|USING|AFTER|FIRST)$/) {
          break;
        }
        if (out != "") {
          out = out " ";
        }
        out = out token;
      }
      print out;
    }
  ' <<< "$line"
}

append_default_fields() {
  cat > "$FIELDS_FILE" <<'EOF'
pk_id|pkId|Long|bigint|主键ID|0|1|1|
id|id|Long|bigint|编号|1|0|0|
status|status|Integer|tinyint|状态|1|0|0|
is_deleted|isDeleted|Integer|tinyint|删除标识|1|0|0|
gmt_created|gmtCreated|LocalDateTime|datetime|创建时间|1|0|0|
gmt_modified|gmtModified|LocalDateTime|datetime|更新时间|1|0|0|
gmt_deleted|gmtDeleted|LocalDateTime|datetime|删除时间|1|0|0|
create_by|createBy|String|varchar(64)|创建人|1|0|0|64
update_by|updateBy|String|varchar(64)|更新人|1|0|0|64
remark|remark|String|varchar(255)|备注信息|1|0|0|255
EOF
}

parse_ddl_fields() {
  local normalized primary_columns primary_csv
  normalized="$(normalize_ddl)"
  primary_csv="$(printf '%s\n' "$normalized" | sed -nE 's/.*PRIMARY[[:space:]]+KEY[[:space:]]*\(([^)]*)\).*/\1/ip' | head -n 1 | tr -d '` ')"
  : > "$FIELDS_FILE"

  while IFS= read -r line; do
    local trimmed column raw_type java_type comment nullable primary auto size field
    trimmed="$(sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//; s/,$//' <<< "$line")"

    if [[ -z "$trimmed" ]]; then
      continue
    fi
    if [[ "$trimmed" =~ ^(CREATE[[:space:]]+TABLE|\)|PRIMARY[[:space:]]+KEY|UNIQUE[[:space:]]+(KEY|INDEX)|FULLTEXT[[:space:]]+KEY|SPATIAL[[:space:]]+KEY|FOREIGN[[:space:]]+KEY|KEY[[:space:]]|INDEX[[:space:]]|CONSTRAINT|CHECK[[:space:]]) ]]; then
      continue
    fi
    if [[ ! "$trimmed" =~ ^\`?[A-Za-z0-9_]+\`?[[:space:]]+ ]]; then
      continue
    fi

    column="$(sed -nE 's/^\`?([A-Za-z0-9_]+)\`?.*/\1/p' <<< "$trimmed")"
    raw_type="$(extract_raw_type "$trimmed")"
    java_type="$(map_sql_type "$raw_type")"
    comment="$(extract_comment_from_line "$trimmed")"
    nullable="1"
    if [[ "$trimmed" =~ NOT[[:space:]]+NULL ]]; then
      nullable="0"
    fi
    primary="0"
    if [[ ",${primary_csv}," == *",${column},"* ]] || [[ "$trimmed" =~ PRIMARY[[:space:]]+KEY ]]; then
      primary="1"
    fi
    auto="0"
    if [[ "$trimmed" =~ AUTO_INCREMENT ]]; then
      auto="1"
    fi
    size="$(extract_size "$raw_type")"
    field="$(snake_to_camel "$column")"
    [ -z "$comment" ] && comment="$field"

    printf '%s|%s|%s|%s|%s|%s|%s|%s|%s\n' \
      "$column" "$field" "$java_type" "$raw_type" "$comment" "$nullable" "$primary" "$auto" "$size" >> "$FIELDS_FILE"
  done <<< "$normalized"

  if [ ! -s "$FIELDS_FILE" ]; then
    echo "DDL 解析失败，没有拿到字段定义" >&2
    exit 1
  fi
}

prepare_fields() {
  if [ -n "$DDL" ]; then
    if [ -z "$TABLE_NAME" ]; then
      TABLE_NAME="$(extract_table_name_from_ddl)"
    fi
    parse_ddl_fields
  else
    append_default_fields
  fi
}

column_exists() {
  grep -q "^$1|" "$FIELDS_FILE"
}

column_comment() {
  local column="$1"
  local value
  value="$(awk -F'|' -v target="$column" '$1 == target { print $5; exit }' "$FIELDS_FILE")"
  if [ -n "$value" ]; then
    printf '%s' "$value"
  else
    printf '%s' "$column"
  fi
}

is_audit_field() {
  case "$1" in
    pk_id|id|is_deleted|gmt_created|gmt_modified|gmt_deleted|create_by|update_by) return 0 ;;
    *) return 1 ;;
  esac
}

is_vo_hidden_field() {
  case "$1" in
    is_deleted|gmt_deleted) return 0 ;;
    *) return 1 ;;
  esac
}

is_page_hidden_field() {
  case "$1" in
    pk_id|is_deleted|gmt_deleted|create_by|update_by) return 0 ;;
    *) return 1 ;;
  esac
}

is_code_field() {
  local column="$1" field="$2"
  [[ "$column" == "code" || "$column" == *_code || "$field" == "code" || "$field" == *Code ]]
}

is_name_like_field() {
  local column="$1" field="$2"
  [[ "$column" == "name" || "$column" == *_name || "$column" == "title" || "$column" == *_title || "$field" == "name" || "$field" == *Name || "$field" == "title" || "$field" == *Title ]]
}

resolve_delete_mode() {
  if column_exists "is_deleted"; then
    printf 'soft-delete'
  else
    printf 'hard-delete'
  fi
}

resolve_order_by() {
  if column_exists "gmt_created"; then
    printf 'b.gmt_created DESC'
    return
  fi
  if column_exists "gmt_modified"; then
    printf 'b.gmt_modified DESC'
    return
  fi
  if column_exists "pk_id"; then
    printf 'b.pk_id DESC'
    return
  fi
  if column_exists "id"; then
    printf 'b.id DESC'
    return
  fi
  printf '1 DESC'
}

render_model_field_block() {
  local column="$1" field="$2" java_type="$3" comment="$4" primary="$5" size="$6"
  local escaped_comment example
  escaped_comment="$(escape_java "$comment")"
  example="$(default_example "$java_type")"

  if [ "$column" = "status" ]; then
    cat <<EOF
    @Schema(description = "${escaped_comment}", allowableValues = {"0", "1", "9"}, example = "1")
    private Integer status = 1;
EOF
    return
  fi

  if [ "$column" = "is_deleted" ]; then
    cat <<EOF
    @Schema(description = "${escaped_comment}", allowableValues = {"0", "1"}, example = "0")
//    @TableField(fill = FieldFill.INSERT) // 新增时默认填充0
    private Integer isDeleted = 0;
EOF
    return
  fi

  if [ "$primary" = "1" ] || [ "$column" = "pk_id" ]; then
    cat <<EOF
    @Schema(description = "${escaped_comment}", example = "${example}")
    @TableId(type = IdType.AUTO)
    private ${java_type} ${field};
EOF
    return
  fi

  if [ "$column" = "id" ]; then
    if [ "$java_type" = "Long" ]; then
      cat <<EOF
    @Schema(description = "${escaped_comment}", example = "${example}")
//    @TableField(fill = FieldFill.INSERT) // 仅新增时填充
    private ${java_type} ${field} = IdGeneratorUtils.getRandomLongID();
EOF
      return
    fi
    cat <<EOF
    @Schema(description = "${escaped_comment}", example = "${example}")
//    @TableField(fill = FieldFill.INSERT) // 仅新增时填充
    private ${java_type} ${field};
EOF
    return
  fi

  if [ "$column" = "gmt_created" ]; then
    cat <<EOF
    @Schema(description = "${escaped_comment}", example = "${example}")
//    @TableField(fill = FieldFill.INSERT) // 仅新增时填充
    private ${java_type} ${field};
EOF
    return
  fi

  if [ "$column" = "gmt_modified" ]; then
    cat <<EOF
    @Schema(description = "${escaped_comment}", example = "${example}")
//    @TableField(fill = FieldFill.INSERT_UPDATE) // 新增+更新时填充
    private ${java_type} ${field};
EOF
    return
  fi

  if [ "$column" = "create_by" ]; then
    cat <<EOF
    @Schema(description = "${escaped_comment}", example = "${example}")
//    @TableField(fill = FieldFill.INSERT) // 仅新增时填充
    private ${java_type} ${field};
EOF
    return
  fi

  if [ "$column" = "update_by" ]; then
    cat <<EOF
    @Schema(description = "${escaped_comment}", example = "${example}")
//    @TableField(fill = FieldFill.INSERT_UPDATE) // 新增+更新时填充
    private ${java_type} ${field};
EOF
    return
  fi

  cat <<EOF
    @Schema(description = "${escaped_comment}", example = "${example}")
    private ${java_type} ${field};
EOF
}

render_req_field_block() {
  local kind="$1" column="$2" field="$3" java_type="$4" comment="$5" nullable="$6" size="$7"
  local escaped_comment example block validation="" required_mode="Schema.RequiredMode.NOT_REQUIRED"
  escaped_comment="$(escape_java "$comment")"
  example="$(default_example "$java_type")"

  if [ "$kind" = "create" ] && [ "$nullable" = "0" ]; then
    required_mode="Schema.RequiredMode.REQUIRED"
    if is_string_type "$java_type"; then
      validation="    @NotBlank(message = \"${escaped_comment}不能为空\")"$'\n'"${validation}"
    else
      validation="${validation}    @NotNull(message = \"${escaped_comment}不能为空\")"$'\n'
    fi
  fi

  if is_string_type "$java_type"; then
    if [ -n "$size" ]; then
      validation="${validation}    @Size(max = ${size}, message = \"${escaped_comment}长度不能超过${size}个字符\")"$'\n'
    fi
  fi

  if [ "$column" = "status" ] && [ "$kind" = "create" ]; then
    block="$(cat <<EOF
${validation}    @Schema(description = "${escaped_comment}", requiredMode = ${required_mode}, allowableValues = {"0", "1", "9"}, example = "1")
    private Integer status = 1;
EOF
)"
  else
    block="$(cat <<EOF
${validation}    @Schema(description = "${escaped_comment}", requiredMode = ${required_mode}, example = "${example}")
    private ${java_type} ${field};
EOF
)"
  fi

  printf '%s\n' "$block"
}

render_vo_field_block() {
  local column="$1" field="$2" java_type="$3" comment="$4"
  local escaped_comment example
  escaped_comment="$(escape_java "$comment")"
  example="$(default_example "$java_type")"
  cat <<EOF
    @Schema(description = "${escaped_comment}", example = "${example}")
    private ${java_type} ${field};
EOF
}

render_page_field_block() {
  local field="$1" java_type="$2" comment="$3"
  local escaped_comment example
  escaped_comment="$(escape_java "$comment")"
  example="$(default_example "$java_type")"
  cat <<EOF
    @Schema(description = "${escaped_comment}", example = "${example}")
    private ${java_type} ${field};
EOF
}

render_model() {
  local model_package
  model_package="$(path_to_package "$MODEL_PATH")"
  cat <<EOF
package ${BASE_PACKAGE}.${model_package};

import com.baomidou.mybatisplus.annotation.FieldFill;
import com.baomidou.mybatisplus.annotation.IdType;
import com.baomidou.mybatisplus.annotation.TableField;
import com.baomidou.mybatisplus.annotation.TableId;
import com.baomidou.mybatisplus.annotation.TableName;
EOF
  if column_exists "id" && [ "$(awk -F'|' '$1 == "id" { print $3; exit }' "$FIELDS_FILE")" = "Long" ]; then
    cat <<EOF
import com.groupds.gupo.framework.common.utils.IdGeneratorUtils;
EOF
  fi
  cat <<EOF
import io.swagger.v3.oas.annotations.media.Schema;

import lombok.AllArgsConstructor;
import lombok.Data;
import lombok.EqualsAndHashCode;
import lombok.NoArgsConstructor;

import java.io.Serializable;
import java.math.BigDecimal;
import java.time.LocalDateTime;

/**
 * [CRUD-CODEGEN] 本类由 CRUD-CODEGEN 脚手架生成，请结合实际业务调整。
 *
 * ${DISPLAY_NAME}实体
 */
@EqualsAndHashCode(callSuper = false)
@Data
@NoArgsConstructor
@AllArgsConstructor
@Schema(name = "${ENTITY_NAME}", description = "${DISPLAY_NAME}实体")
@TableName("${TABLE_NAME}")
public class ${ENTITY_NAME} implements Serializable {

    private static final long serialVersionUID = 1L;

EOF
  while IFS='|' read -r column field java_type raw_type comment nullable primary auto size; do
    render_model_field_block "$column" "$field" "$java_type" "$comment" "$primary" "$size"
    echo
  done < "$FIELDS_FILE"
  echo "}"
}

render_create_req() {
  local req_package
  req_package="$(path_to_package "$REQ_PATH")"
  cat <<EOF
package ${BASE_PACKAGE}.${req_package};

import io.swagger.v3.oas.annotations.media.Schema;

import lombok.Data;

import jakarta.validation.constraints.NotBlank;
import jakarta.validation.constraints.NotNull;
import jakarta.validation.constraints.Size;
import java.io.Serializable;
import java.math.BigDecimal;
import java.time.LocalDateTime;

/**
 * [CRUD-CODEGEN] 本类由 CRUD-CODEGEN 脚手架生成，请结合实际业务调整。
 *
 * ${DISPLAY_NAME}创建请求
 */
@Data
@Schema(name = "${ENTITY_NAME}CreateReq", description = "${DISPLAY_NAME}创建请求")
public class ${ENTITY_NAME}CreateReq implements Serializable {

EOF
  while IFS='|' read -r column field java_type raw_type comment nullable primary auto size; do
    if is_audit_field "$column"; then
      continue
    fi
    render_req_field_block "create" "$column" "$field" "$java_type" "$comment" "$nullable" "$size"
    echo
  done < "$FIELDS_FILE"
  echo "}"
}

render_update_req() {
  local req_package pk_comment escaped_pk_comment
  req_package="$(path_to_package "$REQ_PATH")"
  pk_comment="$(column_comment "pk_id")"
  escaped_pk_comment="$(escape_java "$pk_comment")"
  cat <<EOF
package ${BASE_PACKAGE}.${req_package};

import io.swagger.v3.oas.annotations.media.Schema;

import lombok.Data;

import jakarta.validation.constraints.NotBlank;
import jakarta.validation.constraints.NotNull;
import jakarta.validation.constraints.Size;
import java.io.Serializable;
import java.math.BigDecimal;
import java.time.LocalDateTime;

/**
 * [CRUD-CODEGEN] 本类由 CRUD-CODEGEN 脚手架生成，请结合实际业务调整。
 *
 * ${DISPLAY_NAME}更新请求
 */
@Data
@Schema(name = "${ENTITY_NAME}UpdateReq", description = "${DISPLAY_NAME}更新请求")
public class ${ENTITY_NAME}UpdateReq implements Serializable {

    @NotNull(message = "${escaped_pk_comment}不能为空")
    @Schema(description = "${escaped_pk_comment}", requiredMode = Schema.RequiredMode.REQUIRED, example = "1")
    private Long pkId;

EOF
  while IFS='|' read -r column field java_type raw_type comment nullable primary auto size; do
    case "$column" in
      pk_id|id|is_deleted|gmt_created|gmt_modified|gmt_deleted|create_by|update_by) continue ;;
    esac
    render_req_field_block "update" "$column" "$field" "$java_type" "$comment" "$nullable" "$size"
    echo
  done < "$FIELDS_FILE"
  echo "}"
}

