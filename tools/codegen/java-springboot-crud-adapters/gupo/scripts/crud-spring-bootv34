render_page_req() {
  local req_package
  req_package="$(path_to_package "$REQ_PATH")"
  cat <<EOF
package ${BASE_PACKAGE}.${req_package};

// import com.groupds.gupo.framework.common.data.domain.BaseParam;
import com.groupds.gupo.framework.common.data.domain.PageDomain;
import io.swagger.v3.oas.annotations.media.Schema;

import lombok.Data;
import lombok.EqualsAndHashCode;

import java.math.BigDecimal;
import java.time.LocalDateTime;

/**
 * [CRUD-CODEGEN] 本类由 CRUD-CODEGEN 脚手架生成，请结合实际业务调整。
 *
 * ${DISPLAY_NAME}分页查询请求
 */
@Data
@EqualsAndHashCode(callSuper = true)
@Schema(name = "${ENTITY_NAME}PageReq", description = "${DISPLAY_NAME}分页查询请求")
// 如项目需要，可放开上面的 BaseParam import，并改为继承 BaseParam
public class ${ENTITY_NAME}PageReq extends PageDomain {

    @Schema(description = "页码（默认1）")
    private Integer pageNum = 1;

    @Schema(description = "每页条数（默认10）")
    private Integer pageSize = 10;

    /**
     * [CRUD-CODEGEN] 本方法由 CRUD-CODEGEN 脚手架生成，请结合实际分页基类规范调整。
     *
     * @return 当前页码
     */
    @Override
    public Integer getPageNum() {
        return pageNum == null || pageNum < 1 ? 1 : pageNum;
    }

    /**
     * [CRUD-CODEGEN] 本方法由 CRUD-CODEGEN 脚手架生成，请结合实际分页基类规范调整。
     *
     * @return 每页条数
     */
    @Override
    public Integer getPageSize() {
        return pageSize == null || pageSize < 1 ? 10 : Math.min(pageSize, 100);
    }

EOF
  while IFS='|' read -r column field java_type raw_type comment nullable primary auto size; do
    if is_page_hidden_field "$column"; then
      continue
    fi
    if [ "$column" = "gmt_created" ] || [ "$column" = "gmt_modified" ]; then
      render_page_field_block "${field}Start" "LocalDateTime" "${comment}开始"
      echo
      render_page_field_block "${field}End" "LocalDateTime" "${comment}结束"
      echo
      continue
    fi
    render_page_field_block "$field" "$java_type" "$comment"
    echo
  done < "$FIELDS_FILE"
  echo "}"
}

