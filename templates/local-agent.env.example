# Copy this file to .agent/local-agent.env in the target project.
# .agent/ should stay ignored by git because this file may contain machine-local paths or commands.

# OpenCode command used by scripts/local-agent-loop-example.sh.
# If your OpenCode version does not support "run", use "opencode" and execute tasks manually.
LOCAL_AGENT_COMMAND='opencode run'

# Project validation command used by scripts/run-tests.sh.
# Pick one command that is safe to run locally and does not touch production data.
PROJECT_TEST_COMMAND='mvn test'

# Example when tests need local Docker services:
# PROJECT_TEST_COMMAND='docker compose up -d mysql redis && mvn test'

# Optional deepv4 review through an OpenAI-compatible API.
# Keep these values in .agent/local-agent.env only; do not commit real keys.
# DEEPV4_BASE_URL='https://api.example.com/v1'
# DEEPV4_API_KEY='replace-with-your-key'
# DEEPV4_MODEL='deepv4'
# DEEPV4_TEMPERATURE='0.1'
# DEEPV4_REVIEW_COMMAND='bash scripts/providers/deepv4-openai-compatible.sh'
